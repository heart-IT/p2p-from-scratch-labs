{
  "name": "@heart-it/p2p-sparse-db",
  "version": "0.1.1",
  "description": "heartIT lab #4 — range-query 50 of 10,000 invoices from a remote Hyperbee and count the KB you downloaded. Companion to 'From Logs to Databases'.",
  "main": "index.js",
  "bin": {
    "p2p-sparse-db": "index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "b4a": "^1.6.0",
    "bare-fs": "^4.0.0",
    "bare-os": "^3.0.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.0.0",
    "corestore": "^7.10.0",
    "hyperbee": "^2.27.0",
    "hyperswarm": "^4.17.0"
  },
  "imports": {
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    }
  },
  "pear": {
    "name": "p2p-sparse-db",
    "stage": {
      "entrypoints": [
        "./index.js"
      ],
      "ignore": [
        "/.git",
        "/.github",
        "/node_modules",
        "/test",
        "/.env",
        "/.DS_Store",
        "/README.md"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heart-IT/p2p-from-scratch-labs.git",
    "directory": "p2p-sparse-db"
  },
  "license": "MIT",
  "keywords": [
    "p2p",
    "holepunch",
    "lab",
    "part-4"
  ]
}
