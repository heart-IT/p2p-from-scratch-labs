{
  "name": "@heart-it/p2p-one-truth",
  "version": "0.1.2",
  "description": "heartIT lab #6 — two writers, no server, one deterministic linearized view. Companion to 'Many Writers, One Truth'.",
  "main": "index.js",
  "bin": {
    "p2p-one-truth": "index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "autobase": "^7.28.0",
    "b4a": "^1.6.0",
    "bare-fs": "^4.0.0",
    "bare-os": "^3.0.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.0.0",
    "compact-encoding": "^2.16.0",
    "corestore": "^7.10.0",
    "hyperswarm": "^4.17.0",
    "protomux": "^3.11.0"
  },
  "imports": {
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    }
  },
  "pear": {
    "name": "p2p-one-truth",
    "stage": {
      "entrypoints": [
        "./index.js"
      ],
      "ignore": [
        "/.git",
        "/.github",
        "/node_modules",
        "/test",
        "/.env",
        "/.DS_Store",
        "/README.md"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heart-IT/p2p-from-scratch-labs.git",
    "directory": "p2p-one-truth"
  },
  "license": "MIT",
  "keywords": [
    "p2p",
    "holepunch",
    "lab",
    "part-6"
  ]
}
