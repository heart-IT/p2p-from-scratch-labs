{
  "name": "@heart-it/p2p-hello",
  "version": "0.1.2",
  "description": "heartIT lab #1 — two strangers, one passphrase, a hole-punched encrypted connection. Companion to the P2P from Scratch series.",
  "main": "index.js",
  "bin": {
    "p2p-hello": "index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "b4a": "^1.6.0",
    "bare-process": "^4.0.0",
    "hyperswarm": "^4.17.0",
    "sodium-universal": "^5.0.0"
  },
  "imports": {
    "process": {
      "bare": "bare-process",
      "default": "process"
    }
  },
  "pear": {
    "name": "p2p-hello",
    "stage": {
      "entrypoints": [
        "./index.js"
      ],
      "ignore": [
        "/.git",
        "/.github",
        "/node_modules",
        "/test",
        "/.env",
        "/.DS_Store",
        "/README.md"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heart-IT/p2p-from-scratch-labs.git",
    "directory": "p2p-hello"
  },
  "license": "MIT",
  "keywords": [
    "p2p",
    "hyperswarm",
    "holepunch",
    "hole-punching",
    "lab"
  ]
}
